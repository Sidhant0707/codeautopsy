                >
                  <div className="p-1 rounded-lg bg-black/60 border border-white/10 backdrop-blur-md flex flex-col gap-1 shadow-xl">
                    <button
                      onClick={(e) => {
                        e.stopPropagation();
                        setIsInteractive(true);
